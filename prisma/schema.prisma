generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EntryType {
  TEXT
  PDF
  URL
}

enum MessageRole {
  user
  assistant
}



model Entry {
  id        String     @id @default(cuid())
  type      EntryType
  title     String?
  messages  Message[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Message {
  id        String      @id @default(cuid())
  role      MessageRole
  content   String
  entryId   String
  entry     Entry       @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
}